{
  "name": "kreuzakt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check": "biome check && bunx tsgo --noEmit",
    "f": "biome check --write --unsafe",
    "reset": "rm data/docs-ai* && mv data/originals/* ./data/ingest && rm -rf ./data/thumbnails",
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "eval": "bun run eval/evaluate.ts",
    "test": "bun test",
    "test:integration": "tmpdir=\"$(mktemp -d)\" && trap 'rm -rf \"$tmpdir\"' EXIT && KREUZAKT_RUN_INTEGRATION=1 DATA_DIR=\"$tmpdir\" bun --env-file=.env.local test"
  },
  "dependencies": {
    "@kreuzberg/node": "^4.8.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "kysely": "^0.28.16",
    "kysely-bun-sqlite": "^0.4.0",
    "luxon": "^3.7.2",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260411.1",
    "bun-types": "^1.3.12",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.8"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
