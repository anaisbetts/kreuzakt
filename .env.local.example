# Recommended: OpenRouter (used when OPENAI_* are unset, or always
# in production-style config).
OPENROUTER_KEY=

# Production-style overrides (used when dev-specific vars above are empty).
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Local / alternate endpoint (dev). When set with non-empty values, these
# override OPENAI_BASE_URL / keys in dev (`npm run dev` / `bun dev`). Set up
# Ollama with a local model so working on the app doesn't cost you $$
OPENAI_DEV_URL=
OPENAI_DEV_API_KEY=
OPENAI_DEV_KEY=
OCR_VLM_DEV_MODEL=
METADATA_LLM_DEV_MODEL=

# Models (dev overrides use *_DEV_*; otherwise *_MODEL defaults apply in config).
OCR_VLM_MODEL=
METADATA_LLM_MODEL=
